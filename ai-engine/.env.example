# Roboflow Configuration for YOLOv8 Model
# Get your API key from https://roboflow.com/settings/profile
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Your trained model identifier from Roboflow
# Format: workspace/project/version
ROBOFLOW_MODEL=your_model_slug_here

# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Telegram Alerts
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
CONFIDENCE_ALERT_LEVEL=0.85
ALERT_COOLDOWN=30
